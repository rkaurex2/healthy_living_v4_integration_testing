platform :ios, '16.0'
# Disable CocoaPods analytics to reduce Flutter build latency
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

# Define the build configuration mapping
project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release, 
  'Release' => :release,
}

# Helper to locate Flutter root directory
def flutter_root
  config_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  raise "#{config_path} must exist. Run 'flutter pub get' first." unless File.exist?(config_path)

  File.foreach(config_path) do |line|
    return line.match(/FLUTTER_ROOT=(.*)/)[1].strip if line =~ /FLUTTER_ROOT=/
  end

  raise "FLUTTER_ROOT not found in #{config_path}. Try deleting it and running 'flutter pub get'."
end

# Load Flutter CocoaPods integration
require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

# List of all iOS app targets
all_targets = %w[
  Runner
  dev
  stage
  prod
]

# Install pods for each target
all_targets.each do |target_name|
  target target_name do
    use_frameworks!
    use_modular_headers!

    flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  end
end

# ✅ Combined post_install block
post_install do |installer|

  # App targets that should NOT receive protection
  production_targets = []

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      flags = config.build_settings['OTHER_CFLAGS'] || '$(inherited)'

      # Set deployment target
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
    end
  end
end
