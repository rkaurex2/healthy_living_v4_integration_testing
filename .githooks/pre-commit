#!/usr/bin/env bash
# pre-commit hook — Stale Mock Detection
# Install: git config core.hooksPath .githooks
#
# What it does:
#   1. If mock_helpers.dart (or any file containing @GenerateMocks) changes
#      but no corresponding .mocks.dart file changes, warn the developer.
#   2. If a BLoC or repository source file changes, remind the developer
#      to check whether mocks need regenerating.
#
# This hook does NOT block the commit — it only warns. To regenerate mocks:
#   melos build_mocks

set -euo pipefail

# Colour codes (skip if not a terminal)
if [ -t 1 ]; then
  YELLOW='\033[1;33m'
  CYAN='\033[0;36m'
  RESET='\033[0m'
else
  YELLOW=''
  CYAN=''
  RESET=''
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

WARN=0

# ─── Check 1: Mock helper files changed without .mocks.dart ──────────────────

MOCK_HELPERS_CHANGED=0
MOCKS_DART_CHANGED=0

while IFS= read -r file; do
  case "$file" in
    *mock_helpers.dart|*test_helpers.dart)
      MOCK_HELPERS_CHANGED=1
      ;;
    *.mocks.dart)
      MOCKS_DART_CHANGED=1
      ;;
  esac
done <<< "$STAGED_FILES"

# Also check if any file containing @GenerateMocks changed
GENERATE_MOCKS_CHANGED=0
while IFS= read -r file; do
  if [[ "$file" == *.dart ]] && git diff --cached -- "$file" 2>/dev/null | grep -q '@GenerateMocks\|@GenerateNiceMocks'; then
    GENERATE_MOCKS_CHANGED=1
    break
  fi
done <<< "$STAGED_FILES"

if [ "$MOCK_HELPERS_CHANGED" -eq 1 ] && [ "$MOCKS_DART_CHANGED" -eq 0 ]; then
  echo -e "${YELLOW}⚠  STALE MOCKS WARNING${RESET}"
  echo -e "   Mock helper file(s) changed but no .mocks.dart file was updated."
  echo -e "   Run: ${CYAN}melos build_mocks${RESET}"
  echo ""
  WARN=1
fi

if [ "$GENERATE_MOCKS_CHANGED" -eq 1 ] && [ "$MOCKS_DART_CHANGED" -eq 0 ]; then
  echo -e "${YELLOW}⚠  STALE MOCKS WARNING${RESET}"
  echo -e "   A @GenerateMocks annotation was modified but no .mocks.dart file was updated."
  echo -e "   Run: ${CYAN}melos build_mocks${RESET}"
  echo ""
  WARN=1
fi

# ─── Check 2: BLoC or Repository source changed ─────────────────────────────

BLOC_OR_REPO_CHANGED=0
CHANGED_SOURCES=""

while IFS= read -r file; do
  case "$file" in
    *_bloc.dart|*_repository.dart|*_data_source.dart)
      # Ignore test files and generated files
      if [[ "$file" != *test* ]] && [[ "$file" != *.mocks.dart ]] && [[ "$file" != *.g.dart ]] && [[ "$file" != *.freezed.dart ]]; then
        BLOC_OR_REPO_CHANGED=1
        CHANGED_SOURCES="$CHANGED_SOURCES\n     $file"
      fi
      ;;
  esac
done <<< "$STAGED_FILES"

if [ "$BLOC_OR_REPO_CHANGED" -eq 1 ]; then
  echo -e "${YELLOW}⚠  MOCK CHECK REMINDER${RESET}"
  echo -e "   BLoC/Repository source file(s) changed:"
  echo -e "${CYAN}${CHANGED_SOURCES}${RESET}"
  echo -e "   If you changed a public interface, run: ${CYAN}melos build_mocks${RESET}"
  echo ""
  WARN=1
fi

# ─── Summary ─────────────────────────────────────────────────────────────────

if [ "$WARN" -eq 1 ]; then
  echo -e "   ${YELLOW}Proceeding with commit — these are warnings only.${RESET}"
  echo ""
fi

# Always allow the commit (exit 0)
exit 0
