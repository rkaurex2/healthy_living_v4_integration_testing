# ──────────────────────────────────────────────────────────────────────────────
# .env.test.example — Template for local integration test environment
# ──────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env.test and fill in your staging credentials:
#
#   cp .env.test.example .env.test
#   $EDITOR .env.test
#
# IMPORTANT: .env.test is in .gitignore — it will NOT be committed.
# Never commit real credentials to the repository.
# ──────────────────────────────────────────────────────────────────────────────

# ── Staging API ──────────────────────────────────────────────────────────────
API_URL=https://your-staging-api.example.com

# ── Standard Test Account ────────────────────────────────────────────────────
TEST_ACCOUNT_EMAIL=dschminkey@exsquared.com
TEST_ACCOUNT_PASSWORD=Schmink99!


# ── Premium Test Account ─────────────────────────────────────────────────────
TEST_ACCOUNT_PREMIUM_EMAIL=don.schminkey@yahoo.com
TEST_ACCOUNT_PREMIUM_PASSWORD=Schmink99!

# ── Google Client IDs (optional — needed for social login tests) ─────────────
ANDROID_GOOGLE_CLIENT_ID=
IOS_GOOGLE_CLIENT_ID=
SERVER_GOOGLE_CLIENT_ID=

# ── RevenueCat API Keys (optional — needed for premium feature tests) ────────
ANDROID_REVENUECAT_API_KEY=
IOS_REVENUECAT_API_KEY=

INTEGRATION_TESTS_APPROVED=true
